ARG BUILDER=registry.redhat.io/ubi10/go-toolset:latest
ARG RUNTIME=registry.access.redhat.com/ubi10/ubi-micro:latest

# ---------- build ----------
FROM ${BUILDER} AS build

ARG VERSION=dev

USER root
WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 go build \
    -ldflags "-s -w -X github.com/txsvc/httpsvc/internal/server.Version=${VERSION}" \
    -o httpsvc ./cmd/httpsvc

# ---------- runtime ----------
FROM ${RUNTIME}

ENV SERVICE_NAME=httpsvc
ENV CADDYFILE=/etc/caddy/Caddyfile

# See https://caddyserver.com/docs/conventions#file-locations
ENV XDG_CONFIG_HOME=/config
ENV XDG_DATA_HOME=/data

EXPOSE 80
EXPOSE 443

RUN mkdir -p /config/caddy /data/caddy /etc/caddy/sites /sites

COPY deploy/Caddyfile /etc/caddy/Caddyfile
COPY deploy/sites/ /etc/caddy/sites/
COPY deploy/run /usr/local/bin/run
COPY --from=build /build/httpsvc /usr/bin/httpsvc

RUN chmod +x /usr/local/bin/run /usr/bin/httpsvc

VOLUME /config
VOLUME /data
VOLUME /sites

CMD ["/usr/local/bin/run"]
